# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (used in email links) ───────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_BASE=http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api



# ── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=Cluster0



# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_secure_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=365d

# ── Groq AI ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── SMTP / Email (Gmail example) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=ApexPrep
EMAIL_FROM_ADDRESS=your_email@gmail.com
